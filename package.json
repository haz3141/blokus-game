{
  "name": "cornerfall",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --parallel --filter @cornerfall/server --filter @cornerfall/web dev",
    "dev:network": "pnpm --parallel --filter @cornerfall/server --filter @cornerfall/web dev:network",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^24.6.0",
    "eslint": "^9.36.0",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^3.2.4"
  }
}
