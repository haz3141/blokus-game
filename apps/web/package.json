{
  "name": "@cornerfall/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:network": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -b && vite build",
    "build:sourcemap": "tsc -b && vite build --sourcemap --outDir dist-analyze",
    "bundle:analyze": "pnpm run build:sourcemap && node ./scripts/analyze-bundle.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "STORYBOOK=1 pnpm exec storybook dev -p 6006",
    "storybook:build": "STORYBOOK=1 pnpm exec storybook build",
    "typecheck": "tsc -b",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@cornerfall/game-core": "workspace:*",
    "@cornerfall/protocol": "workspace:*",
    "@react-three/fiber": "^9.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.181.1",
    "tw-animate-css": "^1.4.0",
    "workbox-window": "^7.3.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@storybook/addon-a11y": "10.2.16",
    "@storybook/addon-docs": "10.2.16",
    "@storybook/react-vite": "10.2.16",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.1.0",
    "storybook": "10.2.16",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.1.0"
  }
}
